# /etc/netplan/99_config.yaml
# Managed by Ansible (base_network role)
# Uses 'routes:' syntax — gateway4 is deprecated in Ubuntu 22.04+
network:
  version: 2
  renderer: networkd
  ethernets:
    {{ netplan_interface.stdout }}:
      addresses:
        - {{ static_ip }}/24
      routes:
        - to: default
          via: {{ home_gateway }}
      nameservers:
        addresses: [{{ home_dns_primary }}, {{ home_dns_fallback }}]
        search: [{{ home_domain }}]
