# /etc/nginx/conf.d/grafana.conf
# Managed by Ansible (proxy role)
# Proxies grafana.home.arpa -> grafana container on proxy_net:3000

server {
    listen {{ proxy_internal_https_port }} ssl;
    server_name grafana.{{ home_domain }};

    location / {
        proxy_pass http://grafana:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Required for Grafana live streaming (server-sent events)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 300;
    }
}
