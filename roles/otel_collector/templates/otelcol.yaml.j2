# /etc/otelcol-contrib/config.yaml
# Managed by Ansible (otel_collector role)
# ${CLICKHOUSE_PASSWORD} is injected at runtime from /etc/otelcol-contrib/otelcol.env

receivers:
{% if otel_collect_host_metrics %}
  hostmetrics:
    collection_interval: {{ otel_metrics_interval }}
    scrapers:
      cpu:
      disk:
      filesystem:
        exclude_mount_points:
          mount_points: [/dev, /proc, /sys, /run]
          match_type: strict
      load:
      memory:
      network:
      paging:
      processes:
{% endif %}
{% if otel_collect_journald_logs %}
  journald:
    directory: /run/log/journal
    priority: info
    # Add specific units here to filter; empty means all units
    # units: [sshd, docker, nginx]
{% endif %}
{% if otel_collect_docker_stats %}
  docker_stats:
    endpoint: unix:///var/run/docker.sock
    collection_interval: {{ otel_metrics_interval }}
    timeout: 10s
{% endif %}

processors:
  batch:
    timeout: 5s
    send_batch_size: 1000

  # Detects host info (hostname, OS) and adds as resource attributes
  resourcedetection:
    detectors: [system]
    system:
      hostname_sources: [os]
    timeout: 5s

  # Stamp every signal with a consistent service.name and host.name
  resource:
    attributes:
      - key: service.name
        value: "{{ otel_service_name }}"
        action: upsert
      - key: host.name
        value: "{{ inventory_hostname }}.{{ home_domain }}"
        action: upsert

exporters:
  clickhouse:
    endpoint: tcp://{{ otel_clickhouse_host }}:{{ otel_clickhouse_tcp_port }}
    database: {{ otel_clickhouse_database }}
    username: {{ otel_clickhouse_user }}
    password: "${CLICKHOUSE_PASSWORD}"
    logs_table_name:    otel_logs
    traces_table_name:  otel_traces
    metrics_table_name: otel_metrics
    timeout: 10s
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 30s
      max_elapsed_time: 300s
    sending_queue:
      enabled: true
      num_consumers: 2
      queue_size: 100

  debug:
    verbosity: basic
    sampling_initial: 5
    sampling_thereafter: 100

service:
  telemetry:
    logs:
      level: warn
    metrics:
      readers:
        - pull:
            exporter:
              prometheus:
                host: 0.0.0.0
                port: 8888

  pipelines:
{% if otel_collect_host_metrics or otel_collect_docker_stats %}
    metrics:
      receivers:
{% if otel_collect_host_metrics %}
        - hostmetrics
{% endif %}
{% if otel_collect_docker_stats %}
        - docker_stats
{% endif %}
      processors: [batch, resourcedetection, resource]
      exporters: [clickhouse, debug]
{% endif %}
{% if otel_collect_journald_logs %}
    logs:
      receivers: [journald]
      processors: [batch, resourcedetection, resource]
      exporters: [clickhouse, debug]
{% endif %}
