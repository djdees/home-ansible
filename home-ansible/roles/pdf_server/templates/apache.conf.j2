# /etc/apache2/sites-available/pdf_server.conf
# Managed by Ansible (pdf_server role).
# Replaces the RHEL-style httpd.conf from the original role with a proper
# Debian/Apache2 virtualhost file. The original used ServerRoot /etc/httpd
# and User/Group apache — neither exist on Debian; corrected to www-data.

<VirtualHost *:80>
    ServerAdmin root@localhost
    DocumentRoot {{ pdf_remote_content }}/html

    <Directory "{{ pdf_remote_content }}">
        AllowOverride None
        Require all granted
        Options Indexes FollowSymLinks
        IndexOptions IgnoreCase FancyIndexing FoldersFirst NameWidth=* DescriptionWidth=*
    </Directory>

    <Directory "{{ pdf_remote_content }}/html">
        Options Indexes FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    ErrorLog  ${APACHE_LOG_DIR}/pdf_server_error.log
    CustomLog ${APACHE_LOG_DIR}/pdf_server_access.log combined
</VirtualHost>
