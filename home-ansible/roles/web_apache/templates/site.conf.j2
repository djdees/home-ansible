# /etc/apache2/sites-available/{{ item.name }}.conf
# Managed by Ansible (web_apache role)

<VirtualHost *:80>
    ServerName {{ item.name }}
    DocumentRoot {{ item.root }}

    CustomLog ${APACHE_LOG_DIR}/{{ item.name }}_access.log combined
    ErrorLog  ${APACHE_LOG_DIR}/{{ item.name }}_error.log

    <Directory "{{ item.root }}">
        Options Indexes FollowSymLinks
        AllowOverride None
        Require all granted
{% if item.autoindex | default(false) %}
        IndexOptions IgnoreCase FancyIndexing FoldersFirst NameWidth=* DescriptionWidth=*
{% endif %}
    </Directory>

    # Deny access to hidden files
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>
</VirtualHost>
