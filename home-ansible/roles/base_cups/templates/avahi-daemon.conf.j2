# /etc/avahi/avahi-daemon.conf — managed by Ansible (base_cups role)
# BUG FIXED: hostname was hardcoded to 'scribe' — now {{ inventory_hostname }}

[server]
host-name={{ inventory_hostname }}
use-ipv4=yes
use-ipv6=yes
ratelimit-interval-usec=1000000
ratelimit-burst=1000

[wide-area]
enable-wide-area=yes

[publish]
publish-hinfo=no
publish-workstation=no

[reflector]

[rlimits]
