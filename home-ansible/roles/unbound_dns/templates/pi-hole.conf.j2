# /etc/unbound/unbound.conf.d/pi-hole.conf
# Managed by Ansible (unbound_dns role).
# Single file for all unbound config — avoids duplicate interface/port
# conflicts caused by Debian's include-toplevel directive.

server:
    verbosity: 0

    interface: 127.0.0.1
    port: {{ unbound_port }}
    access-control: 127.0.0.0/8 allow

    do-ip4: {{ unbound_do_ip4 }}
    do-ip6: {{ unbound_do_ip6 }}
    prefer-ip6: {{ unbound_prefer_ip6 }}
    do-udp: {{ unbound_do_udp }}
    do-tcp: {{ unbound_do_tcp }}

    root-hints: "/var/lib/unbound/root.hints"

    harden-glue: yes
    harden-dnssec-stripped: yes
    use-caps-for-id: no
    edns-buffer-size: 1472
    prefetch: yes
    num-threads: {{ unbound_num_threads }}
    so-rcvbuf: {{ unbound_so_rcvbuf }}

    private-address: 192.168.0.0/16
    private-address: 169.254.0.0/16
    private-address: 172.16.0.0/12
    private-address: 10.0.0.0/8
    private-address: fd00::/8
    private-address: fe80::/10

    # ── Internal home.arpa zone ──────────────────────────────────────────────
    # Edit these entries when adding/removing internal hosts, then run:
    #   ansible-playbook playbooks/unbound-setup.yml --tags internal-dns
    local-zone: "home.arpa." static

    # ── Infrastructure ───────────────────────────────────────────────────────
    local-data: "pihole.home.arpa.   IN A 192.168.1.8"
    local-data: "garmr.home.arpa.    IN A 192.168.1.5"
    local-data: "scribe.home.arpa.   IN A 192.168.1.83"

    # ── Raspberry Pi lab nodes ───────────────────────────────────────────────
    local-data: "pi00.home.arpa.     IN A 192.168.1.90"
    local-data: "pi01.home.arpa.     IN A 192.168.1.91"
    local-data: "pi02.home.arpa.     IN A 192.168.1.92"
    local-data: "pi03.home.arpa.     IN A 192.168.1.93"
    local-data: "pi04.home.arpa.     IN A 192.168.1.94"

    # ── scribe (192.168.1.83) — print server, web server ────────────────────
    local-data: "scribe.home.arpa.   IN A 192.168.1.83"
    local-data: "theCity.home.arpa.  IN A 192.168.1.83"


    # ── Server Nodes ────────────────────────────────────────────────
    local-data: "hunin.home.arpa.    IN A 192.168.1.84"
    local-data: "munin.home.arpa.    IN A 192.168.1.85"

    # ── Reverse (PTR) records ────────────────────────────────────────────────
    local-data-ptr: "192.168.1.8   pihole.home.arpa."
    local-data-ptr: "192.168.1.5   garmr.home.arpa."

    local-data-ptr: "192.168.1.90  pi00.home.arpa."
    local-data-ptr: "192.168.1.91  pi01.home.arpa."
    local-data-ptr: "192.168.1.92  pi02.home.arpa."
    local-data-ptr: "192.168.1.93  pi03.home.arpa."
    local-data-ptr: "192.168.1.94  pi04.home.arpa."

    local-data-ptr: "192.168.1.83  scribe.home.arpa."
    local-data-ptr: "192.168.1.84  hunin.home.arpa."
    local-data-ptr: "192.168.1.85  munin.home.arpa."
